{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "gpt-5.5",
    "api_key_env": "OPENAI_API_KEY",
    "base_url": "${OPENAI_BASE_URL}",
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 1,
    "analysis_concurrency": 2,
    "enrichment_concurrency": 1,
    "languages": ["en", "zh"]
  },
  "sources": {
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 25,
      "min_score": 80
    },
    "ossinsight": {
      "enabled": true,
      "period": "past_24_hours",
      "languages": ["All", "Python", "TypeScript"],
      "keywords": [],
      "min_stars": 10,
      "max_items": 20
    },
    "github": [
      {
        "type": "repo_releases",
        "owner": "pytorch",
        "repo": "pytorch",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "langchain-ai",
        "repo": "langchain",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "astral-sh",
        "repo": "uv",
        "enabled": true
      }
    ],
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "name": "机器之心",
        "url": "https://www.jiqizhixin.com/rss",
        "enabled": true,
        "category": "ai-news"
      },
      {
        "name": "36氪",
        "url": "https://36kr.com/feed",
        "enabled": true,
        "category": "business"
      },
      {
        "name": "少数派",
        "url": "https://sspai.com/feed",
        "enabled": true,
        "category": "tech"
      },
      {
        "name": "InfoQ 中文",
        "url": "https://www.infoq.cn/feed",
        "enabled": true,
        "category": "tech"
      },
      {
        "name": "Hacker News 热门",
        "url": "https://hnrss.org/frontpage?points=50&count=15",
        "enabled": true,
        "category": "tech"
      }
    ],
    "reddit": {
      "enabled": false,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 30
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 20
        }
      ],
      "users": [],
      "fetch_comments": 5
    },
    "twitter": {
      "enabled": false,
      "users": ["karpathy", "ylecun"],
      "fetch_limit": 10,
      "fetch_reply_text": false,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 10,
      "reply_min_likes": 5
    }
  },
  "filtering": {
    "ai_score_threshold": 6.0,
    "time_window_hours": 24,
    "max_items": 25,
    "category_groups": {
      "ai": {
        "name": "🤖 AI 前沿",
        "limit": 8,
        "categories": ["ai-news", "ai-tools", "ai-research", "machine-learning"]
      },
      "tech": {
        "name": "💻 技术动态",
        "limit": 8,
        "categories": ["tech", "linux", "programming", "open-source"]
      },
      "business": {
        "name": "📊 商业资讯",
        "limit": 5,
        "categories": ["business", "finance", "startups"]
      }
    },
    "default_group": "other",
    "default_group_limit": 4
  },
  "webhook": {
    "enabled": true,
    "url_env": "FEISHU_WEBHOOK_URL",
    "request_body": {
      "msg_type": "interactive",
      "card": {
        "header": {
          "title": {
            "tag": "plain_text",
            "content": "Horizon #{date} 日报"
          },
          "template": "blue"
        },
        "elements": [
          {
            "tag": "markdown",
            "content": "#{summary}"
          }
        ]
      }
    },
    "delivery": "summary",
    "overview_position": "first",
    "platform": "feishu",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": ["en", "zh"]
  }
}
